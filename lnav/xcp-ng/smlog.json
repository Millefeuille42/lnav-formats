#! /usr/bin/env lnav -i
{
    "$schema": "https://lnav.org/schemas/format-v1.schema.json",
    "smlog": {
        "title": "xcp-ng SMlog file",
        "description": "Parser XCP-NG SMlog files",
        "url": "https://github.com/xcp-ng/sm",

        "file-pattern": "SMlog.*",
        "multiline": false,

        "timestamp-field": "timestamp",
        "body-field": "body",
        "opid-field": "pid",

        "regex": {
            "master": {
                "pattern": "(?J)^(?<timestamp>\\w{3}\\s+\\d{1,2}\\s+(?:\\d{2}:?){3})\\s+(?<host>\\S+)\\s+(?<process>[^:\\s\\[]+)(?::?\\s)?(?:(?:\\[(?<pid>\\d+)\\]:?)|(?::))?\\s+(?:(?:(?:\\*?(?<short_vdi_uuid>[\\w\\d]+))\\[(?<image_format>\\w+)\\]\\((?<vdi_size>\\d+\\.\\d{3}\\w)\\/{3}(?<vdi_real_size>\\d+\\.\\d{3}\\w)\\|\\w+\\)(?::\\s+(?<sm_config>{[^}]+})$)?)|(?:\\[(?<command>'[^\\]]+')\\])|(?:\\*{5}\\s+(?<exception_group>[^:]+):\\s+(?:(?<exception_operation>[^:]+)?:\\s+)?EXCEPTION\\s+<class\\s+'(?<exception_type>[^']+)'>,\\s(?<exception_message>(?:(?:\\[(?<exception_errno>Errno\\s\\d+)\\])\\s)?.+?(?:(?:\\[(?<exception_details>[^\\]]+)\\]))?)$)|(?:(?:(?<sub_component>[\\w-]+):\\s+)?(?<body>.*)))$"
            }
        },
        "value": {
            "timestamp": { "kind": "string", "identifier": true },
            "host": { "kind": "string", "identifier": true },
            "process": { "kind": "string", "identifier": true },
            "pid": { "kind": "integer", "identifier": true },
            "sub_component": { "kind": "string", "identifier": true },
            "body": { "kind": "string" },
            "short_vdi_uuid": { "kind": "string", "identifier": true },
            "image_format": { "kind": "string" },
            "vdi_size": { "kind": "string" },
            "vdi_real_size": { "kind": "string" },
            "sm_config": { "kind": "json" },
            "command": { "kind": "string" },
            "exception_group": { "kind": "string", "identifier": true },
            "exception_operation": { "kind": "string" },
            "exception_type": { "kind": "string", "identifier": true },
            "exception_message": { "kind": "string" },
            "exception_errno": { "kind": "string" },
            "exception_details": { "kind": "string" }
        },
        "highlights": {
            "process_sm": {
                "pattern": "\\bSM\\b",
                "color": "#32a875"
            },
            "process_smgc": {
                "pattern": "\\bSMGC\\b",
                "color": "#75a832"
            },
            "pid": {
                "pattern": "\\[\\d+\\]",
                "color": "#3290a8"
            },
            "uuid": {
                "pattern": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}",
                "color": "#bd93f9"
            },
            "short_uuid": {
                "pattern": "\\*?([0-9a-f]{8})\\[",
                "color": "#bd93f9"
            },
            "command": {
                "pattern": "\\['.*?'\\]",
                "color": "#50fa7b"
            },
            "exception_keyword": {
                "pattern": "EXCEPTION",
                "color": "#ff5555",
                "underline": true
            },
            "error_number": {
                "pattern": "Errno \\d+",
                "color": "#ff5555"
            },
            "vhd_size": {
                "pattern": "\\d+\\.\\d{3}.",
                "color": "#ff79c6"
            },
            "file_path": {
                "pattern": "\\/[\\w\\/.-]+",
                "color": "#f1fa8c"
            }
        },
        "sample": [
            { "line": "Dec 11 11:11:11 my-host fairlock[111]: /run/fairlock/devicemap" },
            { "line": "Dec 11 11:11:11 my-host SM: [2222]  = 0" },
            { "line": "Dec 11 11:11:11 my-host SMGC: [333] SR xxx ('my-sr') (333 VDIs in 33 VHD trees):" },
            { "line": "Dec 11 11:11:11 my-host SMGC: [444]         *xxx[VHD](50.000G///44.444G|n)" }
        ]
    }
}

